<%- include('partials/header', { title: category.name }) %>

<section class="section">
  <div class="container">
    <h1 class="page-title">📁 <%= category.name %></h1>
    <% if (category.description) { %><p class="category-desc"><%= category.description %></p><% } %>
    <div class="media-grid">
      <% mediaList.forEach(item => { %>
      <a href="/medya/<%= item.id %>" class="media-card">
        <div class="media-thumb">
          <% if (item.type === 'image') { %>
          <img src="/uploads/<%= item.filename %>" alt="<%= item.title %>" loading="lazy">
          <% } else { %>
          <div class="video-thumb">
            <video src="/uploads/<%= item.filename %>" preload="metadata"></video>
            <span class="play-icon">▶</span>
          </div>
          <% } %>
          <span class="media-type <%= item.type %>"><%= item.type === 'image' ? '📷' : '🎬' %></span>
        </div>
        <div class="media-info">
          <h3><%= item.title %></h3>
          <div class="meta"><span>👁 <%= item.views %></span><span>⬇ <%= item.downloads %></span></div>
        </div>
      </a>
      <% }) %>
    </div>
    <% if (mediaList.length === 0) { %><p class="empty">Bu kategoride henüz içerik yok.</p><% } %>
  </div>
</section>

<%- include('partials/footer') %>
