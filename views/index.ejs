<%- include('partials/header', { title: 'Ana Sayfa' }) %>

<section class="hero">
  <div class="container">
    <div class="hero-inner">
      <div class="hero-text">
        <span class="hero-label">Fotoğraf & Video</span>
        <h1>Ataberk<em>.</em><br>Taşçı</h1>
        <p class="hero-sub">Fotoğraf ve video koleksiyonum. Anları, yerleri ve hikayeleri keşfet.</p>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <strong><%= recentMedia.filter(m => m.type === 'image').length %>+</strong>
          <span>Fotoğraf</span>
        </div>
        <div class="hero-stat">
          <strong><%= recentMedia.filter(m => m.type === 'video').length %>+</strong>
          <span>Video</span>
        </div>
        <div class="hero-stat">
          <strong><%= categories.length %></strong>
          <span>Kategori</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Son <span>Yüklenenler</span></h2>
      <a href="/fotograflar" class="section-link">Tümünü Gör →</a>
    </div>

    <% if (recentMedia.length > 0) { %>
    <div class="magazine-grid">
      <% recentMedia.forEach(item => { %>
      <a href="/medya/<%= item.id %>" class="media-card">
        <div class="media-thumb">
          <% if (item.type === 'image') { %>
          <img src="/uploads/<%= item.filename %>" alt="<%= item.title %>" loading="lazy">
          <% } else { %>
          <div class="video-thumb">
            <video src="/uploads/<%= item.filename %>" preload="metadata"></video>
            <span class="play-icon">▶</span>
          </div>
          <% } %>
          <div class="media-overlay">
            <% if (item.category_name) { %><span class="tag"><%= item.category_name %></span><% } %>
            <h3><%= item.title %></h3>
            <div class="meta">
              <span>👁 <%= item.views %></span>
              <span>⬇ <%= item.downloads %></span>
            </div>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
    <% } else { %>
    <p class="empty">Henüz içerik yüklenmedi.</p>
    <% } %>
  </div>
</section>

<% if (categories.length > 0) { %>
<section class="section" style="background: var(--dark); padding: 48px 0;">
  <div class="container">
    <div class="section-header" style="border-color: #333;">
      <h2 class="section-title" style="color:#fff;">Kategoriler</h2>
    </div>
    <div style="display:flex; gap:2px; flex-wrap:wrap;">
      <% categories.forEach(cat => { %>
      <a href="/kategori/<%= cat.slug %>" style="background:#1a1a1a; color:#ccc; padding:14px 24px; font-size:0.85rem; font-weight:600; text-transform:uppercase; letter-spacing:1px; transition:all 0.2s;"
         onmouseover="this.style.background='#c8102e';this.style.color='#fff'"
         onmouseout="this.style.background='#1a1a1a';this.style.color='#ccc'">
        <%= cat.name %>
      </a>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<%- include('partials/footer') %>
