<%- include('partials/header', { title: video.snippet.title }) %>

<div class="container media-detail">
  <div class="breadcrumb">
    <a href="/">Ana Sayfa</a> /
    <a href="/youtube">YouTube</a> /
    <span><%= video.snippet.title %></span>
  </div>

  <div class="media-viewer" style="background:#000;aspect-ratio:16/9;">
    <iframe 
      src="https://www.youtube.com/embed/<%= video.id %>?autoplay=1" 
      style="width:100%;height:100%;border:none;"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen>
    </iframe>
  </div>

  <div class="media-meta-bar">
    <div>
      <h1><%= video.snippet.title %></h1>
      <div class="meta-stats">
        <span>👁 <%= parseInt(video.statistics?.viewCount || 0).toLocaleString('tr-TR') %> görüntülenme</span>
        <span>👍 <%= parseInt(video.statistics?.likeCount || 0).toLocaleString('tr-TR') %> beğeni</span>
        <span>📅 <%= new Date(video.snippet.publishedAt).toLocaleDateString('tr-TR') %></span>
        <span class="tag">YouTube</span>
      </div>
      <% if (video.snippet.description) { %>
      <p class="desc" style="margin-top:12px;white-space:pre-line;max-height:100px;overflow:hidden;" id="desc">
        <%= video.snippet.description.substring(0, 300) %><% if (video.snippet.description.length > 300) { %>...
        <a href="#" onclick="document.getElementById('desc').style.maxHeight='none';this.remove();return false;" style="color:var(--accent);">Devamını gör</a>
        <% } %>
      </p>
      <% } %>
    </div>
    <a href="https://www.youtube.com/watch?v=<%= video.id %>" target="_blank" class="btn-download">▶ YouTube'da İzle</a>
  </div>

  <a href="/youtube" style="display:inline-block;margin-bottom:40px;color:var(--text2);font-size:0.9rem;">← Tüm Videolar</a>
</div>

<%- include('partials/footer') %>
